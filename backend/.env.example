APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_PATH=./msalisia_phase1.db
UPLOADS_PATH=./uploads
ADMIN_ACCESS_TOKEN=change-me-admin-token

PRIMARY_LLM_PROVIDER=claude
FALLBACK_LLM_PROVIDER=groq
FALLBACK_ON_LLM_ERROR=true

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions

MAX_OUTPUT_TOKENS=1200
CHAT_MAX_OUTPUT_TOKENS=800
ASSESSMENT_MAX_OUTPUT_TOKENS=1600
REPORT_MAX_OUTPUT_TOKENS=1600
HOMEWORK_MAX_OUTPUT_TOKENS=1000
CLASSIFIER_MAX_OUTPUT_TOKENS=220
TEMPERATURE=0.35

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SIGNUP_CODE_TTL_MINUTES=10
SIGNUP_CODE_MAX_ATTEMPTS=5
